{
  "name": "@lukethacoder/storybook-addon-shiki",
  "version": "1.0.0",
  "description": "A Storybook addon that replaces react-syntax-highlighter with Shiki for beautiful, accurate syntax highlighting",
  "keywords": [
    "shiki",
    "syntax highlighting",
    "code block"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lukethacoder/storybook-addon-shiki.git"
  },
  "license": "MIT",
  "author": "lukethacoder",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./manager": "./dist/manager.js",
    "./preview": {
      "types": "./dist/preview.d.ts",
      "default": "./dist/preview.js"
    },
    "./preset": "./dist/preset.js",
    "./options": "./src/options-runtime.ts",
    "./package.json": "./package.json"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "manager.js",
    "preset.js",
    "preview.js",
    "README.md",
    "!dist/**/*.map"
  ],
  "scripts": {
    "prebuild": "node -e \"fs.rmSync('./dist', { recursive: true, force: true })\"",
    "build": "tsup",
    "build-storybook": "storybook build",
    "build:watch": "npm run build -- --watch",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "lint:fix": "pnpm lint --fix",
    "prerelease": "zx scripts/prepublish-checks.js",
    "release": "npm run build && auto shipit",
    "start": "run-p build:watch \"storybook --quiet\"",
    "storybook": "storybook dev -p 6006",
    "sb": "storybook dev -p 6006 --no-open",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "shiki": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@fontsource-variable/fira-code": "^5.2.7",
    "@shikijs/colorized-brackets": "^4.0.2",
    "@shikijs/transformers": "^4.0.2",
    "@storybook/addon-docs": "10.3.1",
    "@storybook/icons": "^2.0.0",
    "@storybook/react-vite": "10.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "^4.1.0",
    "auto": "^11.3.0",
    "boxen": "^8.0.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-storybook": "10.3.1",
    "happy-dom": "^20.8.4",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "prompts": "^2.4.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "10.3.1",
    "ts-dedent": "^2.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.44.1",
    "vite": "^7.0.5",
    "vitest": "^4.1.0",
    "zx": "^8.7.1"
  },
  "peerDependencies": {
    "shiki": ">=1.0.0",
    "storybook": "10.3.1"
  },
  "peerDependenciesMeta": {
    "@shikijs/transformers": {
      "optional": true
    },
    "@shikijs/colorized-brackets": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "bundler": {
    "exportEntries": [
      "src/index.ts",
      "src/ShikiHighlighter.tsx",
      "src/highlighter.ts"
    ],
    "managerEntries": [
      "src/manager.ts"
    ],
    "previewEntries": [
      "src/preview.ts",
      "src/shims/load-options.ts",
      "src/ShikiHighlighter.tsx",
      "src/highlighter.ts"
    ],
    "nodeEntries": [
      "src/preset.ts"
    ]
  },
  "storybook": {
    "displayName": "Shiki Syntax Highlighter",
    "supportedFrameworks": [
      "react",
      "vue3",
      "angular",
      "svelte",
      "ember",
      "html",
      "web-components",
      "preact",
      "solid",
      "qwik"
    ],
    "icon": "https://shiki.style/logo.svg",
    "preset": "./dist/preset.js"
  },
  "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c"
}
